# Django settings module
# Development: portfolio.settings.dev
# Production:  portfolio.settings.prod
DJANGO_SETTINGS_MODULE=portfolio.settings.dev

# Core Django settings
SECRET_KEY=change-me-before-deploying
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Database
# Leave DATABASE_URL blank in development to use SQLite.
# Production expects a PostgreSQL URL, for example:
# DATABASE_URL=postgresql://portfolio:password@localhost:5432/portfolio
DATABASE_URL=
DATABASE_CONN_MAX_AGE=60
DATABASE_SSL_REQUIRE=False

# Chat endpoint controls
CHAT_MESSAGE_MAX_LENGTH=2000
CHAT_HISTORY_MESSAGE_MAX_LENGTH=4000
CHAT_HISTORY_MAX_MESSAGES=12
CHAT_THROTTLE_RATE=60/hour

# Logging
LOG_LEVEL=INFO

# Production security settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# LLM providers
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OLLAMA_MODEL=llama3.2
